# MongoDB Atlas connection string (see server/README.md or PROJECT_BRIEF.md for setup steps)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/jobtracker?retryWrites=true&w=majority

# Port the Express server listens on locally
PORT=5000

# Secret used to sign login JWTs - use a long random string, keep it out of git
JWT_SECRET=change-me-to-a-long-random-string

# Credentials for the admin account auto-created on first boot (only runs
# when the users collection is empty). To change it later, use the admin's
# own entry in the Users tab rather than editing these env vars.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Gmail account used to send password-reset emails. GMAIL_APP_PASSWORD is a
# Google App Password (not the account's login password) - requires 2FA on
# the Gmail account, generated at myaccount.google.com/apppasswords.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=change-me

# Frontend origin used to build password-reset links in emails.
# http://localhost:5173 in dev; the deployed URL (e.g. Render) in production.
CLIENT_URL=http://localhost:5173
